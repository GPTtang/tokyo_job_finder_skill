{
  "_comment": "Copy this file to sources.json and customize. sources.json is gitignored.",
  "sources": [
    {
      "_comment": "Ashby: set 'board' to the company's Ashby board slug",
      "provider": "ashby",
      "board": "your-company",
      "filters": {
        "keywords": ["engineer", "software", "data"],
        "locations": ["Tokyo", "Japan", "Remote"]
      }
    },
    {
      "_comment": "Greenhouse: set 'token' to the company's Greenhouse token",
      "provider": "greenhouse",
      "token": "your-company",
      "filters": {
        "keywords": ["engineer", "developer"],
        "locations": ["Tokyo", "Japan"]
      }
    },
    {
      "_comment": "Lever: set 'company' to the company's Lever slug",
      "provider": "lever",
      "company": "your-company",
      "filters": {
        "locations": ["Tokyo", "Japan"]
      }
    },
    {
      "_comment": "Company site: provide a direct job listing URL",
      "provider": "company_site",
      "url": "https://example.com/careers",
      "filters": {
        "keywords": ["engineer"]
      }
    },
    {
      "_comment": "japan-dev.com: no extra params required",
      "provider": "japan_dev",
      "filters": {
        "keywords": ["engineer", "developer", "software"],
        "locations": ["Tokyo", "Japan", "Remote"]
      }
    }
  ]
}
